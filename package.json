{
  "name": "web-t-search",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "build": "rm -rf dist && mkdir dist && mkdir dist/frontend && bun build src/index.ts --outdir dist --target bun && cp -r src/frontend/* dist/frontend"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "hono": "^4.9.2"
  }
}
